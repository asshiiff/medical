<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.monitorExamStatusController">
   <children>
      <TableView fx:id="candidateTable" layoutX="24.0" layoutY="88.0" prefHeight="201.0" prefWidth="548.0">
        <columns>
          <TableColumn fx:id="candidateIdCol" prefWidth="75.0" text="Candidate ID" />
          <TableColumn fx:id="candidateNameCol" prefWidth="75.0" text="Candidate Name" />
            <TableColumn fx:id="candidateStatusCol" prefWidth="75.0" text="Candidate Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <CheckBox fx:id="examCompletedCheckBox" layoutX="24.0" layoutY="301.0" mnemonicParsing="false" text="Exam Completed?" />
      <Button layoutX="173.0" layoutY="297.0" mnemonicParsing="false" onAction="#updateButton" text="Update" />
      <Button layoutX="14.0" layoutY="360.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <Button layoutX="206.0" layoutY="31.0" mnemonicParsing="false" onAction="#loadCandidatesButton" text="Load Candidates" />
      <ComboBox fx:id="selectExamCB" layoutX="24.0" layoutY="31.0" prefWidth="150.0" promptText="Select Exam" />
   </children>
</AnchorPane>
