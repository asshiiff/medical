      </TableView>
      <Button layoutX="460.0" layoutY="232.0" mnemonicParsing="false" onAction="#deleteButton" text="Delete" />
      <Button layoutX="52.0" layoutY="330.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
