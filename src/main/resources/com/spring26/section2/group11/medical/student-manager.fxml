      <Label fx:id="display2" layoutX="54.0" layoutY="122.0" text="Exam Instructions:" />
      <Label fx:id="display3" layoutX="145.0" layoutY="149.0" text="1. Read all questions carefully." />
      <Label fx:id="display4" layoutX="145.0" layoutY="192.0" text="2. Do not close the system during exam." />
      <Label fx:id="display5" layoutX="145.0" layoutY="234.0" text="3. One answer per question." />
      <Label fx:id="display6" layoutX="145.0" layoutY="273.0" text="4. Click “Start Exam” to begin." />
      <Button layoutX="225.0" layoutY="319.0" mnemonicParsing="false" onAction="#startExamButton" text="Start Exam" />
   </children>
</AnchorPane>
