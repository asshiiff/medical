<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashif.SaveQuestionBankController">
   <children>
      <TextArea fx:id="textArea" layoutX="35.0" layoutY="45.0" prefHeight="200.0" prefWidth="200.0" promptText="Question Input" />
      <TableView fx:id="questionTable" layoutX="258.0" layoutY="45.0" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="questionCol" prefWidth="75.0" text="Save Questions" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ComboBox fx:id="subjectCB" layoutX="35.0" layoutY="268.0" prefWidth="150.0" promptText="Subject" />
      <ComboBox fx:id="difficultyCB" layoutX="247.0" layoutY="268.0" prefWidth="150.0" promptText="Difficulty" />
      <Button layoutX="432.0" layoutY="268.0" mnemonicParsing="false" text="Add Question " />
      <Label fx:id="display" layoutX="35.0" layoutY="342.0" prefHeight="17.0" prefWidth="265.0" />
   </children>
</AnchorPane>
