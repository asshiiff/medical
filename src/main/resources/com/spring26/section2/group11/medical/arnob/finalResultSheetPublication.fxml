<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="563.0" prefWidth="770.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.finalResultSheetPublicationController">
   <children>
      <Label fx:id="display1" layoutX="302.0" layoutY="14.0" text="Prepare Final Result Sheet">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TableView fx:id="resultTable" layoutY="169.0" prefHeight="200.0" prefWidth="772.0">
        <columns>
          <TableColumn fx:id="studentIdCol" prefWidth="75.0" text="Student ID" />
          <TableColumn fx:id="marksCol" prefWidth="75.0" text="Marks" />
            <TableColumn fx:id="gradeCol" prefWidth="75.0" text="Grade" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="295.0" layoutY="389.0" mnemonicParsing="false" onAction="#publishButton" prefHeight="39.0" prefWidth="144.0" text="Publish Results" />
      <Label fx:id="finalresultLabel" layoutX="290.0" layoutY="475.0" prefHeight="39.0" prefWidth="257.0" textFill="#c60f0f">
         <font>
            <Font name="System Bold" size="16.0" />
         </font></Label>
      <Button layoutX="626.0" layoutY="124.0" mnemonicParsing="false" onAction="#loadButton" prefHeight="27.0" prefWidth="106.0" text="Load Result" />
      <Button layoutX="65.0" layoutY="492.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <TextField fx:id="studentIdField" layoutX="53.0" layoutY="79.0" prefHeight="45.0" prefWidth="149.0" promptText="Student ID" />
      <TextField fx:id="marksField" layoutX="247.0" layoutY="79.0" prefHeight="45.0" prefWidth="149.0" promptText="Marks" />
      <TextField fx:id="gradeField" layoutX="433.0" layoutY="79.0" prefHeight="45.0" prefWidth="170.0" promptText="Grade" />
      <Button layoutX="626.0" layoutY="396.0" mnemonicParsing="false" onAction="#refreshButton" prefHeight="45.0" prefWidth="77.0" text="Refresh" />
   </children>
</AnchorPane>
