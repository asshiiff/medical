<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.manageAnswerKeyController">
   <children>
      <Label fx:id="display" layoutX="206.0" layoutY="14.0" text="Manage Answer Key">
         <font>
            <Font name="System Bold" size="21.0" />
         </font>
      </Label>
      <TableView fx:id="answerTable" layoutY="66.0" prefHeight="200.0" prefWidth="359.0">
        <columns>
          <TableColumn fx:id="courseCol" prefWidth="75.0" text="Course" />
          <TableColumn fx:id="answerKeyCol" prefWidth="75.0" text="Answer Key" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ComboBox fx:id="courseCB" layoutX="379.0" layoutY="97.0" prefWidth="150.0" promptText="Course" />
      <ComboBox fx:id="semesterCB" layoutX="379.0" layoutY="141.0" prefWidth="150.0" promptText="Semester" />
      <TextField fx:id="answerKeyField" layoutX="380.0" layoutY="200.0" promptText="Answer Key" />
      <Button layoutX="281.0" layoutY="299.0" mnemonicParsing="false" onAction="#saveButton" prefHeight="31.0" prefWidth="67.0" text="Save" />
      <Label layoutX="301.0" layoutY="356.0" text="Successful" />
   </children>
</AnchorPane>
