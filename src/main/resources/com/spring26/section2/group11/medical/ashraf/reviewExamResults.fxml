<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="476.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.reviewExamResultsController">
   <children>
      <ComboBox fx:id="selectExamCB" layoutX="28.0" layoutY="32.0" prefWidth="150.0" promptText="Select Exam" />
      <TableView fx:id="resultsTable" layoutX="28.0" layoutY="83.0" prefHeight="201.0" prefWidth="552.0">
        <columns>
          <TableColumn fx:id="studentNameCol" prefWidth="75.0" text="Student Name" />
          <TableColumn fx:id="scoreCol" prefWidth="75.0" text="Score" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="206.0" layoutY="32.0" mnemonicParsing="false" onAction="#loadExamResultsButton" text="Load Exam Results" />
      <PieChart fx:id="passFailPercentPieChart" layoutX="52.0" layoutY="301.0" prefHeight="90.0" prefWidth="163.0" />
      <Button layoutX="14.0" layoutY="439.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
