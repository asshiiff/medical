<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.EvalutorCreatesRankingController">
   <children>
      <Label fx:id="display1" layoutX="225.0" layoutY="32.0" prefHeight="29.0" prefWidth="150.0" text="Exam Ranking">
         <font>
            <Font name="System Bold" size="21.0" />
         </font>
      </Label>
      <Button layoutX="231.0" layoutY="77.0" mnemonicParsing="false" onAction="#generateRankingButton" text="Generate Ranking" />
      <Label fx:id="display2" layoutX="215.0" layoutY="121.0" prefHeight="20.0" prefWidth="171.0" text="Exam Ranking Successfully">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <TableView fx:id="rankTable" layoutY="149.0" prefHeight="200.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="rankCol" prefWidth="75.0" text="Rank" />
          <TableColumn fx:id="studentNameCol" prefWidth="75.0" text="Student Name" />
            <TableColumn fx:id="studentIDCol" prefWidth="75.0" text="Student ID" />
            <TableColumn fx:id="marksCol" prefWidth="75.0" text="Marks" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="79.0" layoutY="361.0" mnemonicParsing="false" onAction="#saveRankingButton" text="Save Ranking" />
      <Button layoutX="360.0" layoutY="361.0" mnemonicParsing="false" onAction="#exportPDFButton" text="Export as PDF" />
   </children>
</AnchorPane>
