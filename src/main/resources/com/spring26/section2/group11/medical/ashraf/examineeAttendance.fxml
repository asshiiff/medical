<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.examineeAttendanceController">
   <children>
      <ComboBox fx:id="examsCB" layoutX="149.0" layoutY="46.0" prefWidth="150.0" promptText="Exams" />
      <TableView fx:id="attendanceTable" layoutX="150.0" layoutY="100.0" prefHeight="202.0" prefWidth="432.0">
        <columns>
          <TableColumn fx:id="candidateNameCol" prefWidth="75.0" text="Candidate Name" />
          <TableColumn fx:id="candidateIdCol" prefWidth="75.0" text="Candidate ID" />
            <TableColumn fx:id="attendanceCol" prefWidth="75.0" text="Attended Exam?" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="149.0" layoutY="360.0" mnemonicParsing="false" onAction="#submitAttendanceButton" text="Submit Attendance" />
      <Button layoutX="319.0" layoutY="46.0" mnemonicParsing="false" onAction="#loadStudentListButton" text="Load Student List" />
      <Button layoutX="14.0" layoutY="360.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <Button layoutX="149.0" layoutY="315.0" mnemonicParsing="false" onAction="#giveAttendanceButton" text="Give Attendance" />
      <Label fx:id="displayLabel" layoutX="300.0" layoutY="364.0" prefHeight="19.0" prefWidth="282.0" />
   </children>
</AnchorPane>
