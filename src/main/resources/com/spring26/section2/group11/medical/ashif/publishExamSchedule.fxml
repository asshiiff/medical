<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashif.PublishExamScheduleController">
   <children>
      <TextField fx:id="usernameField" layoutX="47.0" layoutY="45.0" promptText="Username" />
      <TextField fx:id="passwordField" layoutX="245.0" layoutY="45.0" promptText="Password" />
      <TableView fx:id="examlistTable" layoutX="50.0" layoutY="100.0" prefHeight="200.0" prefWidth="482.0">
        <columns>
          <TableColumn fx:id="examlistCol" prefWidth="75.0" text="Examlist" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="480.0" layoutY="45.0" mnemonicParsing="false" onAction="#loginButton" text="Login" />
      <Button layoutX="427.0" layoutY="315.0" mnemonicParsing="false" onAction="#publishButton" text="Publish Schedule" />
      <Label fx:id="display" layoutX="49.0" layoutY="332.0" prefHeight="17.0" prefWidth="226.0" />
   </children>
</AnchorPane>
