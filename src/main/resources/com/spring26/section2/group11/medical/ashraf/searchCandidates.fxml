<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.searchCandidatesController">
   <children>
      <TextField fx:id="candidateIdField" layoutX="37.0" layoutY="41.0" promptText="Candidate ID" />
      <Button layoutX="231.0" layoutY="41.0" mnemonicParsing="false" onAction="#searchCandidate" text="Search Candidate" />
      <TableView fx:id="candidateTable" layoutX="37.0" layoutY="100.0" prefHeight="201.0" prefWidth="542.0">
        <columns>
          <TableColumn fx:id="candidateIdCol" prefWidth="75.0" text="Candidate ID" />
          <TableColumn fx:id="candidateNameCol" prefWidth="75.0" text="Candidate Name" />
            <TableColumn fx:id="candidateExamCol" prefWidth="75.0" text="Candidate Exam " />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
