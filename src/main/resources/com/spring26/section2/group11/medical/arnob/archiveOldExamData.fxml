<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.archiveOldExamDataController">
   <children>
      <TableView fx:id="oldExamTable" layoutY="59.0" prefHeight="200.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="subjectCol" prefWidth="75.0" text="Subject" />
          <TableColumn fx:id="semesterCol" prefWidth="75.0" text="Semester" />
            <TableColumn fx:id="dateCol" prefWidth="75.0" text="Exam Date" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label fx:id="display1" layoutX="195.0" layoutY="14.0" text="Archive Old Exam Data">
         <font>
            <Font name="System Bold" size="21.0" />
         </font>
      </Label>
      <Button layoutX="274.0" layoutY="292.0" mnemonicParsing="false" onAction="#dataButton" prefHeight="53.0" prefWidth="84.0" text="Archive Data" />
      <Label fx:id="display2" layoutX="448.0" layoutY="345.0" text="Data Archive Data Done" />
      <Button layoutX="34.0" layoutY="350.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
