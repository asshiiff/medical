<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashif.AssignInvigilatorsController">
   <children>
      <ComboBox fx:id="invigilatorCB" layoutX="41.0" layoutY="33.0" prefWidth="150.0" promptText="Select Invigilator" />
      <TableView fx:id="invigilatorTable" layoutX="46.0" layoutY="75.0" prefHeight="200.0" prefWidth="501.0">
        <columns>
          <TableColumn fx:id="examCenterCol" prefWidth="75.0" text="Exam Centers" />
          <TableColumn fx:id="invigilatorListCol" prefWidth="75.0" text="Invigilator List" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="496.0" layoutY="295.0" mnemonicParsing="false" onAction="#assignButton" text="Assign" />
      <Label fx:id="display" layoutX="46.0" layoutY="346.0" prefHeight="17.0" prefWidth="205.0" />
      <Button layoutX="46.0" layoutY="295.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <ComboBox fx:id="examCenterCB" layoutX="397.0" layoutY="33.0" prefWidth="150.0" promptText="Exam Center" />
   </children>
</AnchorPane>
