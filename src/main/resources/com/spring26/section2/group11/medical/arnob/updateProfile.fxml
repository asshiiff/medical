<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.updateProfileController">
   <children>
      <Label fx:id="display1" layoutX="236.0" layoutY="14.0" text="My Profile">
         <font>
            <Font name="System Bold" size="26.0" />
         </font>
      </Label>
      <Label fx:id="display2" layoutX="53.0" layoutY="68.0" text="Select  what you Change" textFill="#eb0b0b" />
      <Label fx:id="display3" layoutX="118.0" layoutY="125.0" text="Name  :" />
      <Label fx:id="display4" layoutX="122.0" layoutY="175.0" prefHeight="17.0" prefWidth="34.0" text="Age  :" />
      <TextField fx:id="nameField" layoutX="169.0" layoutY="121.0" />
      <TextField fx:id="ageField" layoutX="169.0" layoutY="171.0" />
      <Button layoutX="318.0" layoutY="286.0" mnemonicParsing="false" onAction="#updateButton" prefHeight="34.0" prefWidth="60.0" text="Update" />
      <Label fx:id="updateSuccessfullLabel" layoutX="267.0" layoutY="336.0" prefHeight="25.0" prefWidth="163.0" textFill="#900f0f" />
      <Label fx:id="display5" layoutX="99.0" layoutY="221.0" text="Password  :" />
      <TextField fx:id="passwordField" layoutX="169.0" layoutY="217.0" />
      <Button layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <TableView fx:id="studentProfileTable" layoutX="332.0" layoutY="75.0" prefHeight="172.0" prefWidth="250.0">
        <columns>
          <TableColumn fx:id="studentNameCol" prefWidth="113.0" text="Student Name" />
          <TableColumn fx:id="ageCol" prefWidth="53.0" text="Age" />
            <TableColumn fx:id="passwordCol" prefWidth="75.0" text="Password" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
