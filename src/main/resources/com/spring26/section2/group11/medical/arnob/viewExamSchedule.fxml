<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.viewExamScheduleController">
   <children>
      <Label fx:id="display1" layoutX="223.0" layoutY="14.0" prefHeight="27.0" prefWidth="137.0" text="Exam Schedule">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TableView fx:id="examTable" layoutX="-1.0" layoutY="52.0" prefHeight="241.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="subjectCol" prefWidth="75.0" text="Subject" />
          <TableColumn fx:id="dateCol" prefWidth="75.0" text="Date" />
            <TableColumn fx:id="roomCol" prefWidth="75.0" text="Room" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="19.0" layoutY="360.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
