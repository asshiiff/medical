<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.viewExamScheduleController">
   <children>
      <Label fx:id="display1" layoutX="223.0" layoutY="14.0" prefHeight="27.0" prefWidth="137.0" text="Exam Schedule">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TableView fx:id="examTable" layoutX="-1.0" layoutY="52.0" prefHeight="157.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="examNameCol" prefWidth="75.0" text="Exam Name " />
          <TableColumn fx:id="dateCol" prefWidth="75.0" text="Date" />
            <TableColumn fx:id="timeCol" prefWidth="75.0" text="Time" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label fx:id="display2" layoutX="45.0" layoutY="227.0" prefHeight="20.0" prefWidth="62.0" text="Details :">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <TextArea fx:id="detailsArea" layoutX="76.0" layoutY="253.0" prefHeight="63.0" prefWidth="431.0" text="room 101&#10;select exam see " />
      <Button layoutX="317.0" layoutY="347.0" mnemonicParsing="false" onAction="#nextButton" prefHeight="25.0" prefWidth="90.0" text="Next" />
      <Button layoutX="19.0" layoutY="360.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
