<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.ChecksAnswersAndGivesMarksController">
   <children>
      <Label fx:id="display2" layoutX="90.0" layoutY="71.0" prefHeight="17.0" prefWidth="113.0" text="Upload Answer File :" />
      <TextField fx:id="fileField" layoutX="210.0" layoutY="67.0" />
      <Button layoutX="405.0" layoutY="67.0" mnemonicParsing="false" onAction="#uploadButton" text="Upload" />
      <Label fx:id="display3" layoutX="263.0" layoutY="133.0" prefHeight="17.0" prefWidth="97.0" text="File Check Done" />
      <TableView fx:id="answerTable" layoutX="-6.0" layoutY="161.0" prefHeight="171.0" prefWidth="612.0">
        <columns>
          <TableColumn fx:id="studentIdCol" prefWidth="75.0" text="Student ID" />
          <TableColumn fx:id="marksCol" prefWidth="75.0" text="Marks" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label fx:id="display1" layoutX="187.0" layoutY="14.0" text="Checks Answers And Gives Marks">
         <font>
            <Font name="System Bold" size="16.0" />
