<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.arnob.ChecksAnswersAndGivesMarksController">
   <children>
      <TextField fx:id="studentIdField" layoutX="113.0" layoutY="54.0" prefHeight="35.0" prefWidth="166.0" promptText="Student ID" />
      <Button layoutX="363.0" layoutY="80.0" mnemonicParsing="false" onAction="#uploadButton" prefHeight="42.0" prefWidth="76.0" text="Upload" />
      <TableView fx:id="answerTable" layoutX="-1.0" layoutY="161.0" prefHeight="171.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="studentIdCol" prefWidth="75.0" text="Student ID" />
          <TableColumn fx:id="marksCol" prefWidth="75.0" text="Marks" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label fx:id="display1" layoutX="187.0" layoutY="14.0" text="Checks Answers And Gives Marks">
