<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashif.CategorizeQuestionsController">
   <children>
      <TableView fx:id="questionsTable" layoutX="60.0" layoutY="28.0" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="questionsCol" prefWidth="75.0" text="Questions" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ComboBox fx:id="categoryCB" layoutX="300.0" layoutY="34.0" prefWidth="150.0" promptText="Category" />
      <Button layoutX="357.0" layoutY="115.0" mnemonicParsing="false" onAction="#assignButton" text="Assign Category" />
   </children>
</AnchorPane>
