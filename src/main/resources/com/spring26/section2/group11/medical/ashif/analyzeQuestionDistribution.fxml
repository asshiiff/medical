<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashif.AnalyzeQuestionDistributionController">
   <children>
      <TableView fx:id="questionDistributionTable" layoutX="53.0" layoutY="64.0" prefHeight="200.0" prefWidth="500.0">
        <columns>
          <TableColumn fx:id="eventCol" prefWidth="75.0" text="Event" />
          <TableColumn fx:id="descriptionCol" prefWidth="75.0" text="Description" />
            <TableColumn fx:id="typeCol" prefWidth="75.0" text="Type" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="397.0" layoutY="309.0" mnemonicParsing="false" onAction="#saveQuestionDescriptionButton" text="Save Question Description" />
      <Label fx:id="display" layoutX="14.0" layoutY="360.0" prefHeight="17.0" prefWidth="238.0" />
      <Button layoutX="53.0" layoutY="309.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
