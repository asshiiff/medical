<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.incidentReportController">
   <children>
      <ComboBox fx:id="examCB" layoutX="150.0" layoutY="30.0" prefWidth="150.0" promptText="Exam" />
      <TableView fx:id="studentTable" layoutX="150.0" layoutY="70.0" prefHeight="201.0" prefWidth="433.0">
        <columns>
          <TableColumn fx:id="canidateNameCol" prefWidth="75.0" text="Canidate Name" />
          <TableColumn fx:id="candidateIdCol" prefWidth="75.0" text="Candidate Id" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ComboBox fx:id="incidentCB" layoutX="150.0" layoutY="298.0" prefWidth="150.0" promptText="Incident" />
      <Button layoutX="150.0" layoutY="348.0" mnemonicParsing="false" onAction="#printReportButton" text="Save Report" />
      <Button layoutX="14.0" layoutY="362.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
      <Label fx:id="displayLabel" layoutX="267.0" layoutY="352.0" prefHeight="19.0" prefWidth="189.0" />
      <Button layoutX="316.0" layoutY="30.0" mnemonicParsing="false" onAction="#loadCandidateList" text="Load Candidate List" />
   </children>
</AnchorPane>
