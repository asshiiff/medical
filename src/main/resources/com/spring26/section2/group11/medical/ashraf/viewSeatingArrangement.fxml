<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group11.medical.ashraful.viewSeatingArrangementController">
   <children>
      <TableView fx:id="candidateTable" layoutX="21.0" layoutY="80.0" prefHeight="201.0" prefWidth="543.0">
        <columns>
          <TableColumn fx:id="candidateIdCol" prefWidth="75.0" text="Candidate Id" />
          <TableColumn fx:id="candidateNameCol" prefWidth="75.0" text="Candidate Name" />
            <TableColumn fx:id="candidateSeatCol" prefWidth="75.0" text="Candidate Seat" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="21.0" layoutY="35.0" mnemonicParsing="false" onAction="#viewSeatingArrangmentButton" text="View Seating Arrangement" />
   </children>
</AnchorPane>
